                        }
                    }
                }
            }
        },
        "/rooms/{roomID}": {
            "get": {
                "description": "Returns metadata for a specific room including online user count.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "rooms"
                ],
                "summary": "Get room details",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "Room ID",
                        "name": "roomID",
